# Environment Variables Template
# Copy this to .env and fill in YOUR LOCAL values
# ⚠️ NEVER COMMIT .env FILE — IT CONTAINS REAL SECRETS
# ✅ This file (.env.example) is safe to commit — contains no real values

# ═════════════════════════════════════════════════════════════════════════════
# INCIDENT RESPONSE CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Analyst name (for reports and logs)
ANALYST_NAME="Your Name Here"

# Email for notifications
ANALYST_EMAIL="your.email@example.com"

# Case number or incident ID
CASE_NUMBER="IR-2026-001"

# Days of logs to collect
DAYS_LOOKBACK=14

# External drive letter (for evidence collection)
EVIDENCE_DRIVE="E"

# Local output directory (if not using external drive)
OUTPUT_ROOT="C:\IREvidence"

# ═════════════════════════════════════════════════════════════════════════════
# FIREWALL & NETWORK CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# MSP/IT Provider subnets (for allowing remote access)
MSP_SUBNET="203.0.113.50/32"

# Your office subnet (for local-only rules)
LOCAL_SUBNET="192.168.1.0/24"

# IRS e-file servers (ProSeries)
IRS_MEFS_SERVER="efts.irs.gov"
IRS_LA_SERVER="la.www4.irs.gov"
IRS_SA_SERVER="sa.www4.irs.gov"

# QuickBooks multi-user ports
QB_PORT_1=8019
QB_PORT_2=56728

# ═════════════════════════════════════════════════════════════════════════════
# REMOTE ACCESS TOOLS — AUTHORIZED SESSION IDs ONLY
# ═════════════════════════════════════════════════════════════════════════════

# Legitimate ScreenConnect session ID (verify with MSP before using)
LEGITIMATE_SCREENCONNECT_ID="bec82a294218ab1e"

# Suspicious/attacker ScreenConnect session ID (if identified)
ATTACKER_SCREENCONNECT_ID="f2b64c8c0b737dc1"

# Other authorized remote tools
AUTHORIZED_MSP_TOOL="SuperOps RMM"

# ═════════════════════════════════════════════════════════════════════════════
# WAZUH SIEM CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════

# Wazuh manager IP address (for agent deployment)
WAZUH_MANAGER_IP="192.168.1.50"

# Wazuh manager port
WAZUH_MANAGER_PORT=1514

# Wazuh agent name (hostname)
WAZUH_AGENT_NAME="JL-W1"

# ═════════════════════════════════════════════════════════════════════════════
# LOGGING & MONITORING
# ═════════════════════════════════════════════════════════════════════════════

# Enable verbose logging
VERBOSE_LOGGING=true

# Log file location
LOG_FILE="C:\Logs\incident_response.log"

# Preserve logs for (days)
LOG_RETENTION_DAYS=365

# ═════════════════════════════════════════════════════════════════════════════
# CUSTOMER/FIRM INFORMATION (For Notification Letters)
# ═════════════════════════════════════════════════════════════════════════════

# Firm name
FIRM_NAME="Your Tax Firm Name"

# Firm address
FIRM_ADDRESS="123 Main St, Your City, ST 12345"

# Firm email
FIRM_EMAIL="security@yourtaxfirm.com"

# Firm phone
FIRM_PHONE="555-1234"

# State for breach notification (affects notification timeline)
BREACH_NOTIFICATION_STATE="CA"

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL: API KEYS FOR THREAT INTELLIGENCE
# These are ONLY needed if integrating with external services
# ═════════════════════════════════════════════════════════════════════════════

# For IP geolocation (optional — uses free API if not provided)
# IPAPI_KEY="your_ipapi_key_here"

# For VirusTotal scanning (optional)
# VIRUSTOTAL_API_KEY="your_virustotal_key_here"

# For abuse.ch lookup (optional)
# ABUSEIPDB_API_KEY="your_abuseipdb_key_here"

# ═════════════════════════════════════════════════════════════════════════════
# NOTES
# ═════════════════════════════════════════════════════════════════════════════

# HOW TO USE:
# 1. Copy this file to .env: cp .env.example .env
# 2. Edit .env with YOUR actual values
# 3. Add .env to .gitignore (already done)
# 4. NEVER commit .env to GitHub
#
# SECURITY:
# - .env is YOUR local configuration — never shared or committed
# - Use different values per machine (analyst workstation, server, etc.)
# - If a value in .env is compromised, rotate it immediately
# - Keep .env.example generic and safe — no real credentials
#
# VERIFICATION:
# - Confirm .env is excluded: git check-ignore .env
# - Never commit .env: git status (should not show .env)
# - Before push: git diff --cached | grep -i "password\|key\|secret" (should be empty)
